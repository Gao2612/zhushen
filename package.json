{
  "name": "zhushen-game",
  "version": "1.1.1",
  "description": "诸神终应知晓玩家自制史记 Android 与桌面应用",
  "main": "desktop/main.js",
  "scripts": {
    "verify": "node scripts/verify-project.js",
    "build": "npm run verify && node scripts/build-android.js debug",
    "build:release": "npm run verify && node scripts/build-android.js release",
    "package:pc": "node scripts/package-pc.js",
    "desktop:win": "npm run verify && electron-builder --win dir --x64",
    "desktop:win:portable": "npm run verify && electron-builder --win portable --x64",
    "desktop:linux": "npm run verify && electron-builder --linux AppImage zip --x64",
    "desktop:mac": "npm run verify && electron-builder --mac dmg zip --x64",
    "installer-shell:win": "npm run verify && electron-builder --win dir --x64 && electron-builder --config launcher-shell/electron-builder.json --win dir --x64 && node scripts/build-installer-shell.js",
    "test:asar-copy": "electron scripts/test-asar-copy.js",
    "test:client-navigation": "electron scripts/test-client-navigation.js",
    "lint:android": "cd android && gradlew.bat :app:lintDebug --no-daemon"
  },
  "build": {
    "appId": "com.zhushen.archive",
    "productName": "诸神终应知晓",
    "executableName": "zhushen-archive",
    "artifactName": "zhushen-archive-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "releases/desktop"
    },
    "files": [
      "desktop/**/*",
      "manual-build/assets/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "manual-build/assets/audio/**/*",
      "manual-build/assets/logo/**/*"
    ],
    "compression": "maximum",
    "win": {
      "icon": "manual-build/assets/logo/logo.ico",
      "signExecutable": false,
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "manual-build/assets/logo/logo.png",
      "category": "Utility",
      "target": [
        "AppImage",
        "zip"
      ]
    },
    "mac": {
      "icon": "manual-build/assets/logo/logo.png",
      "category": "public.app-category.reference",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "keywords": [
    "game",
    "mobile",
    "android"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^3.4.19"
  }
}
